{
  "name": "lookbook",
  "version": "2.3.13",
  "description": "A native development UI for ViewComponent",
  "type": "module",
  "scripts": {
    "dev": "node scripts/bundle.js --watch",
    "build": "node scripts/bundle.js",
    "lint:fix": "bundle exec standardrb --fix && prettier --write .",
    "release": "release-it --verbose",
    "release:dry-run": "release-it --dry-run --verbose"
  },
  "author": "Mark Perkins",
  "license": "MIT",
  "dependencies": {
    "@alpinejs/anchor": "^3.14.9",
    "@alpinejs/collapse": "^3.14.9",
    "@alpinejs/morph": "^3.14.9",
    "@alpinejs/persist": "^3.14.9",
    "@alpinejs/resize": "^3.14.9",
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/source-code-pro": "^5.2.6",
    "@imacrayon/alpine-ajax": "^0.12.4",
    "@phosphor-icons/web": "^2.1.2",
    "alpinejs": "^3.14.9",
    "open-props": "^1.7.16",
    "prism-code-editor": "^4.1.0",
    "split-grid": "^1.0.11",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@chialab/esbuild-plugin-postcss": "^0.18.0",
    "alias-hq": "^4.0.0",
    "esbuild": "^0.25.9",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "lint-staged": "^16.1.5",
    "postcss": "^8.5.6",
    "postcss-custom-media": "^11.0.6",
    "postcss-import": "^16.1.1",
    "postcss-import-url": "^7.2.0",
    "postcss-nesting": "^13.0.2",
    "postcss-preset-env": "^10.2.4",
    "postcss-url": "^10.1.3",
    "prettier": "3.5.3",
    "release-it": "^17.2.1"
  },
  "prettier": {
    "tabWidth": 2,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5"
  },
  "lint-staged": {
    "!(docs/**/*)": [
      "prettier --write --ignore-unknown",
      "npm run build"
    ],
    "**/*.rb": [
      "bundle exec standardrb --fix"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(${branchName}) release ${version}"
    },
    "github": {
      "release": true,
      "releaseName": "Release ${version}"
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": [
        "npm ci",
        "bundle install",
        "bundle exec rspec",
        "bundle exec rake test"
      ],
      "after:bump": [
        "bundle exec appraisal install",
        "npm run lint:fix",
        "npm run build"
      ],
      "after:version:bump": "./bin/bump-version ${version} && bundle",
      "after:release": "printf \"\n\n💎 And updated version of the Lookbook gem (v${version}) will be automatically generated and pushed to RubyGems using Github Actions.\""
    }
  }
}
