
<%= content_for(:main) do %>
  <%= SplitLayout id: "workspace", orientation: :vertical do |layout| %>
    <% layout.with_pane do %>
      <%= Partial :sidebar %>
    <% end %>
    <% layout.with_pane do %>
      <%= yield %>
    <% end %>
  <% end %>
<% end %>

<%= render template: "layouts/lookbook/#{ajax_request? ? "ajax" : "application"}" %>
