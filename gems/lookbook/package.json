{
  "name": "lookbook",
  "version": "4.0.0-pre.0",
  "description": "A UI development environment for Ruby on Rails applications",
  "private": true,
  "type": "module",
  "author": "Mark Perkins",
  "license": "MIT",
  "dependencies": {
    "@ark-ui/svelte": "^5.16.0",
    "@fontsource-variable/inconsolata": "^5.2.8",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@poppanator/sveltekit-svg": "^6.0.1",
    "@inertiajs/svelte": "^2.3.13",
    "@radix-ui/colors": "^3.0.0",
    "dompurify": "^3.3.1",
    "lucide-svelte": "^0.563.0",
    "qs-esm": "^7.0.3",
    "runed": "^0.37.1",
    "svelte": "^5.50.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "postcss-custom-media": "^12.0.0",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "postcss-preset-env": "^11.1.3",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.4.1",
    "shiki-codegen": "^3.22.0",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4"
  },
  "release-it": {
    "git": {
      "commitMessage": "Release ${version}"
    },
    "github": {
      "release": true,
      "releaseName": "Release ${version}"
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": [
        "npm ci",
        "bundle install",
        "bundle exec rspec",
        "bundle exec rake test"
      ],
      "after:bump": [
        "bundle exec appraisal install",
        "npm run lint:fix",
        "npm run build"
      ],
      "after:version:bump": "./bin/bump-version ${version} && bundle",
      "after:release": "printf \"\n\n💎 And updated version of the Lookbook gem (v${version}) will be automatically generated and pushed to RubyGems using Github Actions.\""
    }
  }
}
